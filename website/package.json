{
  "name": "nextjs-nav-guard-website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:css": "tailwindcss -i src/styles.css -o public/styles.css --watch",
    "dev": "tailwindcss -i src/styles.css -o public/styles.css && vite dev",
    "build:css": "tailwindcss -i src/styles.css -o public/styles.css --minify",
    "build": "npm run build:css && vite build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "hono": "^4"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0",
    "tailwindcss": "3",
    "vite": "^6"
  }
}
